# .dockerignore - Improved for smaller build context

# Version Control
.git/
.gitignore
.github/

# Node.js - Global Ignore
**/node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm/
.eslintcache
package-lock.json (Keep for build? No, Dockerfile uses its own npm ci)
# Wait, Dockerfile COPY backend/package*.json ./
# So the root package-lock.json isn't needed.

# Frontend & External Projects (The biggest source of bloat)
frontend/
packages/
workers/
terraform/
**/build/
**/dist/
**/.dart_tool/
**/.pub-cache/
**/.pub/
**/ios/.symlinks/
**/ios/Pods/
**/.flutter-plugins*
**/*.iml

# IDEs & System Files
.vscode/
.idea/
.continue/
.claude/
.agents/
.gemini/
.DS_Store
Thumbs.db

# Temporary Files, Logs & Data
**/logs/
**/*.log
**/temp/
**/uploads/
**/tmp/
**/cache/
**/.cache/
**/scratch/
temp_raw_downloads/
temp_social_uploads/
analyzer_output.txt
final_analyze.txt

# Local Configuration & Secrets
.env*
**/*.pem
**/*.key
serviceAccountKey.json

# Deployment Configs (Excluded from context to prevent accidental inclusion)
fly.toml
Dockerfile
.dockerignore
nixpacks.toml
