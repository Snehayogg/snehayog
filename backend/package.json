{
  "name": "snehayog-backend",
  "version": "1.0.0",
  "description": "Snehayog Backend with Ultra-Fast Video Processing",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "worker": "node workers/videoWorker.js",
    "worker:dubbing": "node workers/dubbingWorker.js",
    "worker:social": "node workers/socialWorker.js",
    "dev": "nodemon server.js",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js --config jest.config.cjs",
    "setup": "npm install && npm run setup:ffmpeg",
    "setup:ffmpeg": "node scripts/setup-ffmpeg.js"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.972.0",
    "@aws-sdk/s3-request-presigner": "^3.990.0",
    "@upstash/redis": "^1.36.2",
    "@xenova/transformers": "^2.17.2",
    "adm-zip": "^0.5.16",
    "axios": "^1.12.2",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.66.6",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.21.2",
    "express-rate-limit": "^6.11.2",
    "ffmpeg-static": "^5.2.0",
    "ffprobe-static": "^3.1.0",
    "firebase-admin": "^13.6.0",
    "fluent-ffmpeg": "^2.1.3",
    "form-data": "^4.0.4",
    "google-auth-library": "^10.3.0",
    "googleapis": "^171.4.0",
    "helmet": "^7.2.0",
    "ioredis": "^5.9.2",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^7.8.7",
    "morgan": "^1.10.1",
    "multer": "^1.4.5-lts.1",
    "newrelic": "^13.10.0",
    "node-cron": "^4.2.1",
    "onnxruntime-node": "^1.24.2",
    "rate-limit-redis": "^4.3.1",
    "razorpay": "^2.9.6",
    "redis": "^5.9.0",
    "sharp": "^0.32.6",
    "sherpa-onnx-node": "^1.12.25",
    "sib-api-v3-sdk": "^8.5.0",
    "wavefile": "^11.0.0"
  },
  "devDependencies": {
    "jest": "^29.6.2",
    "nodemon": "^3.0.1",
    "supertest": "^6.3.3"
  },
  "type": "module",
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=8.0.0"
  },
  "keywords": [
    "video-processing",
    "quality-optimization",
    "ultra-fast-loading",
    "adaptive-streaming",
    "hls",
    "ffmpeg"
  ],
  "author": "Snehayog Team",
  "license": "MIT"
}
